<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.kde.pave.Daemon">
    <method name="windowActivated">
      <arg name="data" type="s" direction="in"/>
    </method>
    <method name="windowClosed">
      <arg name="windowId" type="s" direction="in"/>
    </method>
    <method name="triggerAction">
      <arg name="action" type="s" direction="in"/>
    </method>
    <method name="getState">
      <arg name="result" type="s" direction="out"/>
    </method>
    <method name="resetState"/>
  </interface>
</node>
